{
  "name": "ebay-auto-lister",
  "version": "1.0.0",
  "description": "eBay product listing automation — CSV generation + Seller Hub upload",
  "scripts": {
    "build": "./node_modules/.bin/tsc",
    "task:import": "npm run build && node dist/tasks/import-from-1688source.js",
    "task:csv": "npm run build && node dist/tasks/task1-csv-gen.js",
    "task:csv:regen": "npm run build && node dist/tasks/task1-csv-gen.js --regenerate",
    "task:upload": "npm run build && node dist/tasks/task2-upload.js",
    "task:login": "npm run build && node dist/tasks/task2-upload.js --login"
  },
  "keywords": [
    "ebay",
    "automation",
    "dropshipping"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "dotenv": "^16.0.0",
    "mysql2": "^3.16.3",
    "puppeteer": "^24.37.5",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "winston": "^3.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0"
  }
}
